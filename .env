# ============================================================
# ADAPTIVE HEALTH MANAGEMENT PLATFORM
# .env — Environment Variables
# ============================================================

FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-very-secret-key-change-this-in-production-make-it-long

DATABASE_URL=sqlite:///health_tracker.db

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

APP_NAME=HealthTrack
APP_TAGLINE=Your Adaptive Health Recovery Platform
APP_VERSION=1.0.0

UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=5242880

CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=300

WTF_CSRF_ENABLED=True
SESSION_COOKIE_SECURE=False
REMEMBER_COOKIE_DURATION=2592000